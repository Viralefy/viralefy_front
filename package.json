{
  "name": "viralefy_front",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "indexnow": "node scripts/indexnow.mjs",
    "test": "node --import ./tests/ts-loader.mjs --test tests/unit/*.test.mjs",
    "test:smoke": "bash tests/smoke/run.sh",
    "test:pentest": "bash tests/pentest/probes.sh",
    "test:emulated:browse": "node tests/emulated/browse-flow.mjs",
    "test:emulated:checkout": "node tests/emulated/checkout-flow.mjs",
    "test:all": "npm test && npm run test:smoke && npm run test:pentest && npm run test:emulated:browse"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
